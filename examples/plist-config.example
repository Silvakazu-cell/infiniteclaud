<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Identificação básica -->
	<key>CFBundleName</key>
	<string>Lovable App</string>
	<key>CFBundleIdentifier</key>
	<string>com.yourcompany.lovableapp</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0.0</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>

	<!-- Orientação -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<!-- Capacidades requeridas -->
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>

	<!-- Permissões (Privacy) -->
	<key>NSCameraUsageDescription</key>
	<string>Precisamos acessar sua câmera para enviar fotos</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Utilizamos sua localização para melhorar a experiência</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Precisamos acessar suas fotos para compartilhar</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Sua localização é usada para fornecer serviços melhores</string>

	<!-- Capacitor Configuration -->
	<key>NSAllowsArbitraryLoads</key>
	<true/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>localhost</key>
			<dict>
				<key>NSIncludesSubdomains</key>
				<true/>
				<key>NSTemporaryExceptionAllowsInsecureHTTPLoads</key>
				<true/>
			</dict>
		</dict>
	</dict>

	<!-- Launch Screen -->
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>

	<!-- Status Bar -->
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<false/>
	<key>UIStatusBarStyle</key>
	<string>UIStatusBarStyleDefault</string>

	<!-- Minimum iOS Version -->
	<key>MinimumOSVersion</key>
	<string>13.0</string>

	<!-- Firebase Configuration (se usar) -->
	<key>FIREBASE_DATABASE_URL</key>
	<string>https://your-project.firebaseio.com</string>

	<!-- Background Modes (para push notifications) -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
		<string>fetch</string>
	</array>
</dict>
</plist>
